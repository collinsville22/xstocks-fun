{
  "name": "xstocks-fun",
  "version": "1.0.0",
  "private": true,
  "description": "Tokenized stocks trading platform on Solana",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "cd apps/web && npm run build",
    "start": "cd apps/web && npm start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.8.7"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/collinsville22/xstocks-fun.git"
  },
  "author": "xStocks.fun Team",
  "license": "MIT"
}